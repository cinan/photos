---
pagination:
  data: photos
  size: 1
  alias: photo
permalink: "{{ photo.projectSlug }}/{{ photo.slug }}/index.html"
layout: layouts/base.njk
section: photo
eleventyComputed:
  title: "{{ photo.projectTitle }}"
---

{% set imagePath = photo.src %}

<article>

  <header class="pb--4">
    <div class="grid grid--intro">
      <a class="grid__item--span-4 mw--readable link-nostyle" href="/{{ photo.projectSlug }}/">
        <h2>&larr; {{ photo.projectTitle }}</h2>
      </a>
    </div>
  </header>

  <div class="photo-page__image">

    {# Build output formats from settings #}
    {% set outputFormats = [] %}
    {% for format, i in settings.images %}
      {% if i.enabled === true %}
        {{ '' if outputFormats.push(format) }}
      {% endif %}
    {% endfor %}

    {% set params =
      {
        "src": imagePath,
        "alt": photo.projectTitle,
        "loadingType": "eager",
        "viewportSizes": "(min-width: 1140px) 70vw, (min-width: 540px) 90vw, 100vw",
        "outputWidths": [
          settings.config.image_width_sm,
          settings.config.image_width_md,
          settings.config.image_width_lg
        ],
        "outputFormats": outputFormats,
        "outputQualityJpeg": settings.images.jpeg.quality,
        "outputQualityWebp": settings.images.webp.quality,
        "outputQualityAvif": settings.images.avif.quality
      }
    %}

    {% generateImage params %}

  </div>

</article>
